# RxVision — Caddy reverse proxy
#
# Routing:
#   app.rxvision.gr         -> Next.js PWA (web:3000), /api/* -> FastAPI (api:8000)
#   adminpanel.rxvision.gr  -> same web, root rewritten to /admin, /api/* -> api
#
# TLS: controlled by {$CADDY_TLS} (default "internal" = self-signed origin cert).
#   - Works behind Cloudflare in "Full" SSL mode immediately.
#   - To get a publicly-trusted cert behind Cloudflare proxy AFTER you switch the
#     registrar nameservers to Cloudflare, set in .env:
#         CADDY_TLS=dns cloudflare {env.CF_API_TOKEN}
#     (this image is built with the caddy-dns/cloudflare plugin) and set CF_API_TOKEN.

{
	email admin@rxvision.gr
}

# Security response headers (defense-in-depth; applied to every site below).
# NB: no Content-Security-Policy yet — Next.js inline hydration scripts need a nonce
# integration first; clickjacking is covered by X-Frame-Options DENY.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

(api_and_app) {
	import security_headers
	# API first (same-origin -> no CORS), everything else to the web app.
	handle /api/* {
		reverse_proxy api:8000
	}
	handle /health {
		reverse_proxy api:8000
	}
	# Immutable hashed assets — keep Next.js' long-lived cache.
	handle /_next/* {
		reverse_proxy web:3000
	}
	# Service worker must never be cached (so the kill-switch/updates always land).
	handle /sw.js {
		reverse_proxy web:3000 {
			header_down >Cache-Control "no-cache, no-store, must-revalidate"
		}
	}
	# Everything else (HTML documents) — strip the origin's s-maxage (which let Cloudflare
	# cache HTML for a year) and force revalidation, so a redeploy is picked up immediately.
	handle {
		reverse_proxy web:3000 {
			header_down >Cache-Control "no-cache, must-revalidate"
		}
	}
}

app.rxvision.gr {
	tls {$CADDY_TLS:internal}
	import api_and_app
}

adminpanel.rxvision.gr {
	tls {$CADDY_TLS:internal}
	# Land the back-office on /admin by default.
	@root path /
	rewrite @root /admin
	import api_and_app
}

my.rxvision.gr {
	tls {$CADDY_TLS:internal}
	# Patient portal (3rd identity). Land on /portal by default; same web + /api backend.
	@root path /
	rewrite @root /portal
	import api_and_app
}

# Preview access BEFORE the DNS/NS cutover, over plain HTTP on :80 (no cert warning):
#   - open  http://157.180.26.98        (app)  ·  http://157.180.26.98/admin (back-office)
#   - or VS Code "Ports" → forward 80 → http://localhost
# Same-origin /api works. Remove this block once the domains are live.
http://localhost, http://157.180.26.98 {
	import api_and_app
}
