# ── App ─────────────────────────────────────────────
ENV=local
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
# Ingestion: estimate wholesale = retail*(1-pct/100) when neither the source feed nor
# product masterdata provide it (live ΗΔΙΚΑ). Such items are flagged 'estimated'. 0 disables.
WHOLESALE_FALLBACK_MARGIN_PCT=25.0

# ── Mongo (auth ON; replica-set keyfile is auto-generated in a volume) ──
# MONGO_ROOT_* must match the credentials embedded in MONGODB_URI below.
# In prod: use strong, unique values (NOT the dev defaults) — the API refuses to
# boot if MONGODB_URI still contains "change-me-dev-only" while ENV=prod.
MONGO_ROOT_USER=rxvision
MONGO_ROOT_PASSWORD=change-me-dev-only-mongo
MONGODB_URI=mongodb://rxvision:change-me-dev-only-mongo@mongo:27017/?replicaSet=rs0&authSource=admin
MONGODB_DB=rxvision

# ── Redis (auth ON via requirepass) ─────────────────
# REDIS_PASSWORD must match the password embedded in the URLs below.
REDIS_PASSWORD=change-me-dev-only-redis
REDIS_URL=redis://:change-me-dev-only-redis@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-dev-only-redis@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-dev-only-redis@redis:6379/2

# ── Auth (rotate in prod; load from Vault) ──────────
JWT_SECRET=change-me-dev-only
# Separate key for platform-admin tokens (domain separation from tenant tokens).
# MUST differ from JWT_SECRET and from the dev default in prod.
JWT_PLATFORM_SECRET=change-me-dev-only-platform
JWT_ALG=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# ── Secrets / anonymization ─────────────────────────
# In prod these live in Vault, NOT here.
ANONYMIZATION_GLOBAL_PEPPER=change-me-dev-only
# Vault speaks HTTPS (self-signed in-cluster cert). REQUIRED in prod — the API refuses
# to boot without a reachable, authenticated, UNSEALED Vault (no in-memory fallback). Set:
#   VAULT_ADDR=https://vault:8200
#   VAULT_TOKEN=<app token>
#   VAULT_CACERT=/vault/tls/vault.crt   (the cert is mounted read-only into the API)
# Leave VAULT_ADDR/VAULT_TOKEN blank ONLY in local dev to use the in-memory fallback.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_CACERT=

# ── Public TLS (Caddy) ──────────────────────────────
# Default "internal" = self-signed origin cert (works behind Cloudflare "Full").
# For publicly-trusted Let's Encrypt via Cloudflare DNS-01 (DNS is on Cloudflare,
# the CERT is still Let's Encrypt — not Cloudflare's), set on the SERVER's .env:
#   CADDY_TLS=dns cloudflare {env.CF_API_TOKEN}
#   CF_API_TOKEN=<token, scope Zone:DNS:Edit>   # SECRET — server .env only, never here/chat
# then: docker compose -f docker-compose.prod.yml -f infra/compose.tls.yml up -d --build caddy
CADDY_TLS=internal
CF_API_TOKEN=

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Seeding credentials (used by backend/scripts/seed.py) — set real values in .env
SEED_DEMO_EMAIL=owner@example.com
SEED_DEMO_PASSWORD=ChangeMe-Demo-2026!
SEED_PADMIN_EMAIL=admin@example.com
SEED_PADMIN_PASSWORD=ChangeMe-Admin-2026!
SEED_PADMIN_NAME=Platform Admin
